# GM PKI Service — 开发环境配置
#
# 所有配置项均有默认值（见 app/config.py），
# 仅在此覆盖需要修改的项即可。

# ── 应用 ──────────────────────────────────────────────────────
DEBUG=true

# ── 数据库 ────────────────────────────────────────────────────
# SQLite（开发，默认使用 backend/data.db）
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/data.db
#
# MySQL（生产）
# DATABASE_URL=mysql+aiomysql://user:password@host:3306/gm_pki

# ── JWT ──────────────────────────────────────────────────────
# JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── 后端端口 ────────────────────────────────────────────────
# BACKEND_PORT=8000
